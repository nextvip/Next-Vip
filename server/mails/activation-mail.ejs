<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Verify your email – NextVip</title>
    <!--[if mso]>
    <noscript>
      <xml>
        <o:OfficeDocumentSettings>
          <o:PixelsPerInch>96</o:PixelsPerInch>
        </o:OfficeDocumentSettings>
      </xml>
    </noscript>
    <![endif]-->
    <style>
      * {
        box-sizing: border-box;
      }
      body {
        margin: 0;
        padding: 0;
        width: 100%;
        max-width: 100vw;
        overflow-x: hidden;
        font-family: 'Public Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        font-size: 16px;
        line-height: 1.6;
        color: #212B36;
        background-color: #F4F6F8;
        -webkit-text-size-adjust: 100%;
      }
      .preheader {
        display: none;
        max-height: 0;
        overflow: hidden;
      }
      .email-root {
        width: 100%;
        max-width: 100%;
        background-color: #F4F6F8;
        padding: 40px 24px;
      }
      .container {
        width: 100%;
        max-width: 560px;
        margin: 0 auto;
      }
      .card {
        width: 100%;
        max-width: 100%;
        background-color: #FFFFFF;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
      }
      .brand {
        width: 100%;
        background-color: #D9A02A;
        padding: 32px 24px;
        text-align: center;
      }
      .brand-name {
        margin: 0;
        font-size: 24px;
        font-weight: 700;
        letter-spacing: -0.03em;
        color: #000000;
      }
      .main {
        width: 100%;
        padding: 40px 24px 48px;
      }
      .greeting {
        margin: 0 0 8px;
        font-size: 15px;
        font-weight: 600;
        color: #212B36;
      }
      .intro {
        margin: 0 0 32px;
        font-size: 15px;
        color: #212B36;
        line-height: 1.65;
      }
      .code-block {
        width: 100%;
        max-width: 100%;
        background-color: #2C2C2C;
        border: 2px solid #D9A02A;
        border-radius: 12px;
        padding: 28px 20px;
        text-align: center;
        margin: 0 0 20px;
      }
      .code-value {
        display: inline-block;
        max-width: 100%;
        font-size: 28px;
        font-weight: 700;
        letter-spacing: 6px;
        color: #FFFFFF;
        font-family: 'Public Sans', 'SF Mono', Consolas, monospace;
        word-break: break-all;
      }
      .code-actions {
        text-align: center;
        margin: 0 0 32px;
        padding-bottom: 8px;
      }
      .copy-btn {
        display: inline-block;
        background-color: #D9A02A;
        color: #000000;
        border: none;
        padding: 12px 24px;
        border-radius: 10px;
        font-size: 14px;
        font-weight: 600;
        font-family: inherit;
        cursor: pointer;
      }
      .copy-btn:hover {
        background-color: #C49000;
      }
      .expiry {
        margin: 0 0 24px;
        font-size: 14px;
        color: #637381;
        line-height: 1.6;
      }
      .divider {
        height: 1px;
        background-color: #DFE3E8;
        margin: 32px 0 24px;
      }
      .disclaimer {
        margin: 0;
        font-size: 13px;
        color: #637381;
        line-height: 1.6;
      }
      .sign-off {
        margin: 28px 0 0;
        font-size: 15px;
        color: #212B36;
      }
      .footer-wrap {
        width: 100%;
        padding: 32px 24px 40px;
        border-top: 1px solid #DFE3E8;
      }
      .footer-text {
        margin: 0;
        font-size: 12px;
        color: #919EAB;
        line-height: 1.5;
        text-align: center;
      }
    </style>
  </head>
  <body>
    <span class="preheader">Your NextVip verification code is <%= verificationCode %>. Use it to activate your account.</span>
    <div class="email-root">
      <div class="container">
        <div class="card">
          <div class="brand">
            <h1 class="brand-name">NextVip</h1>
          </div>
          <div class="main">
            <p class="greeting">Hello <%= user.name %>,</p>
            <p class="intro">
              Thanks for signing up. Enter the verification code below in the app or website to activate your account.
            </p>
            <div class="code-block">
              <span class="code-value" id="verification-code"><%= verificationCode %></span>
            </div>
            <div class="code-actions">
              <button type="button" class="copy-btn" id="copy-code-btn" onclick="var el=document.getElementById('verification-code'); var code=el?el.textContent.trim():''; if(code && navigator.clipboard){navigator.clipboard.writeText(code).then(function(){var b=document.getElementById('copy-code-btn');if(b){b.textContent='Copied';setTimeout(function(){b.textContent='Copy code';},2000);}});} return false;">Copy code</button>
            </div>
            <p class="expiry">
              This code expires in <%= expiresInMinutes %> minutes. Do not share it with anyone.
            </p>
            <div class="divider"></div>
            <p class="disclaimer">
              If you did not create an account with NextVip, you can safely ignore this email.
            </p>
            <p class="sign-off">Best regards,<br />The NextVip Team</p>
          </div>
          <div class="footer-wrap">
            <p class="footer-text">This message was sent to you because an account was created with this email address. NextVip – Powerlifting coaching platform.</p>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
